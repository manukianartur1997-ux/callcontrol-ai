PORT=8787
HOST=127.0.0.1

# Optional local protection for admin/client API.
APP_PIN=change-me

# Cloudflare Pages Function / Worker secrets.
# ADMIN_TOKEN gates GET /api/leads (and the Worker's other protected
# routes). If it is left unset in the real Cloudflare env, those routes
# fail CLOSED (401 for everyone) - they never fall back to open access.
ADMIN_TOKEN=change-me
TELEGRAM_BOT_TOKEN=replace-in-cloudflare-not-in-html
TELEGRAM_CHAT_ID=replace-in-cloudflare-not-in-html

# Lead-form anti-abuse (all optional; sane defaults are baked into
# lib/lead.js if left unset - see spamReason/checkKvRateLimit there).
# Comma-separated extra origins allowed to call /api/leads via CORS.
# Same-origin requests are always allowed regardless of this list.
ALLOWED_ORIGINS=
# Max lead submissions per IP per RATE_LIMIT_WINDOW_SECONDS (default: 5).
RATE_LIMIT_MAX=
# Rate-limit window in seconds (default: 600 = 10 minutes).
RATE_LIMIT_WINDOW_SECONDS=
# Minimum milliseconds between page load and form submit before a
# submission is treated as a bot (default: 2500).
MIN_FILL_MS=

# Future AI providers.
OPENAI_API_KEY=
TRANSCRIPTION_PROVIDER=manual
