PORT=8787
HOST=127.0.0.1

# Optional local protection for admin/client API.
APP_PIN=change-me

# Cloudflare Pages Function / Worker secrets.
ADMIN_TOKEN=change-me
TELEGRAM_BOT_TOKEN=replace-in-cloudflare-not-in-html
TELEGRAM_CHAT_ID=replace-in-cloudflare-not-in-html

# Lead-form anti-spam (all optional; sensible defaults baked in).
# Comma-separated extra origins allowed to POST /api/leads. Same-origin always works.
ALLOWED_ORIGINS=
# Max lead submissions per IP per window (needs LEADS_KV bound).
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=600
# Min ms a human takes to fill the form; faster = treated as bot.
MIN_FILL_MS=2500

# Future AI providers.
OPENAI_API_KEY=
TRANSCRIPTION_PROVIDER=manual
